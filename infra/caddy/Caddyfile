{
  default_sni 79.137.75.219
}

(picsou_app) {
  encode gzip zstd

  @api path /api/* /auth/* /health
  handle @api {
    reverse_proxy api:8000
  }

  handle {
    reverse_proxy web:3000
  }

  header {
    X-Frame-Options DENY
    X-Content-Type-Options nosniff
    Referrer-Policy strict-origin-when-cross-origin
    Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self'; connect-src 'self' http: https:; script-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
  }
}

http://79.137.75.219 {
  redir https://79.137.75.219{uri} permanent
}

https://79.137.75.219 {
  tls internal {
    key_type rsa2048
  }

  import picsou_app
}

