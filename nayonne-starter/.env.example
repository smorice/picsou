# Domain and app path
NAYONNE_DOMAIN=nayonne.ovh
NAYONNE_BASE_PATH=/nayonne

# API
API_PORT=8082
API_HOST=0.0.0.0
APP_ENV=production
APP_SECRET_KEY=change_me_very_long_secret
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Database
POSTGRES_DB=nayonne
POSTGRES_USER=nayonne_user
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_PORT=5434
DATABASE_URL=postgresql+psycopg://nayonne_user:change_me_db_password@db:5432/nayonne

# Redis
REDIS_PORT=6382
REDIS_URL=redis://redis:6379/0

# MinIO (media storage)
MINIO_PORT=9002
MINIO_CONSOLE_PORT=9003
MINIO_ROOT_USER=nayonne_minio
MINIO_ROOT_PASSWORD=change_me_minio_password
MINIO_BUCKET=media

# Frontend
WEB_PORT=3002
NEXT_PUBLIC_BASE_PATH=/nayonne
NEXT_PUBLIC_API_BASE_URL=/nayonne/api
